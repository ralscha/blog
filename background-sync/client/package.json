{
  "name": "syncclient",
  "version": "0.0.1",
  "scripts": {
    "build": "ng build",
    "dev": "npm-run-all --parallel sw-dev-vite ionic-start",
    "ionic-start": "ionic serve",
    "ng": "ng",
    "postbuild": "npm run sw-prod-vite",
    "serve-dist": "ws --hostname localhost -d dist/app/browser -p 1234 -o --log.format stats",
    "start": "ng serve -o",
    "sw-dev-vite": "rimraf ./src/service-worker.js && vite build --config ./vite.service-worker.config.ts --mode development --watch",
    "sw-prod-vite": "rimraf ./dist/app/browser/service-worker.js && vite build --config ./vite.service-worker.config.ts --mode production && workbox injectManifest ./workbox-config.js",
    "format": "npx prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/common": "22.0.2",
    "@angular/compiler": "22.0.2",
    "@angular/core": "22.0.2",
    "@angular/forms": "22.0.2",
    "@angular/platform-browser": "22.0.2",
    "@angular/router": "22.0.2",
    "@ionic/angular": "8.8.11",
    "dexie": "4.4.4",
    "ionicons": "8.0.13",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "uuid": "14.0.1",
    "workbox-core": "7.4.1",
    "workbox-precaching": "7.4.1",
    "workbox-routing": "7.4.1",
    "workbox-strategies": "7.4.1",
    "workbox-window": "7.4.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular/build": "22.0.3",
    "@angular/cli": "22.0.3",
    "@angular/compiler-cli": "22.0.2",
    "@ionic/angular-toolkit": "12.3.0",
    "local-web-server": "5.4.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "workbox-cli": "7.4.1"
  }
}
