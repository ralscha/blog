{
  "name": "earthquakepwa",
  "version": "0.0.1",
  "scripts": {
    "build": "ng build --base-href /indexeddb/",
    "ng": "ng",
    "postbuild": "bread-compressor dist/app/browser",
    "serve-dist": "ws --hostname localhost -d dist/app/browser -p 1234 -o --log.format stats",
    "start": "ng serve",
    "format": "npx prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "22.0.2",
    "@angular/common": "22.0.2",
    "@angular/compiler": "22.0.2",
    "@angular/core": "22.0.2",
    "@angular/forms": "22.0.2",
    "@angular/platform-browser": "22.0.2",
    "@angular/pwa": "22.0.3",
    "@angular/router": "22.0.2",
    "@angular/service-worker": "22.0.2",
    "@ionic/angular": "8.8.11",
    "geolib": "3.3.14",
    "ionicons": "8.0.13",
    "papaparse": "5.5.4",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular/build": "22.0.3",
    "@angular/cli": "22.0.3",
    "@angular/compiler-cli": "22.0.2",
    "@ionic/angular-toolkit": "12.3.0",
    "@types/papaparse": "5.5.2",
    "bread-compressor-cli": "4.1.0",
    "local-web-server": "5.4.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3"
  }
