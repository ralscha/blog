{
  "name": "earthquakepwa",
  "version": "0.0.1",
  "scripts": {
    "build": "ng build --base-href /indexeddb/",
    "ng": "ng",
    "postbuild": "bread-compressor dist/app/browser",
    "serve-dist": "ws --hostname localhost -d dist/app/browser -p 1234 -o --log.format stats",
    "start": "ng serve",
    "format": "npx prettier --write ."
  },
  "private": true,
  "dependencies": {
