{
  "name": "echartsdemo",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --base-href /echarts/",
    "build-local": "ng build",
    "postbuild": "bread-compressor dist/app",
    "serve-dist": "ws --hostname localhost -d dist/app -p 1234 -o --log.format stats",
    "format": "npx prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/common": "21.2.5",
    "@angular/compiler": "21.2.5",
    "@angular/core": "21.2.5",
    "@angular/forms": "21.2.5",
    "@angular/platform-browser": "21.2.5",
    "@angular/router": "21.2.5",
    "@ionic/angular": "8.8.1",
    "date-fns": "4.1.0",
    "echarts": "6.0.0",
    "ionicons": "8.0.13",
    "ngx-echarts": "21.0.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.3",
    "@angular/cli": "21.2.3",
    "@angular/compiler-cli": "21.2.5",
    "@ionic/angular-toolkit": "12.3.0",
    "@juggle/resize-observer": "3.4.0",
    "bread-compressor-cli": "3.1.2",
    "local-web-server": "5.4.0",
    "resize-observer-polyfill": "1.5.1",
    "typescript": "5.9.3",
    "prettier": "3.8.1"
  }
}
