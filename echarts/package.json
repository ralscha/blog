{
  "name": "echartsdemo",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --base-href /echarts/",
    "build-local": "ng build",
    "postbuild": "bread-compressor dist/app",
    "serve-dist": "ws --hostname localhost -d dist/app -p 1234 -o --log.format stats",
    "format": "npx prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/common": "22.0.2",
    "@angular/compiler": "22.0.2",
    "@angular/core": "22.0.2",
    "@angular/forms": "22.0.2",
    "@angular/platform-browser": "22.0.2",
    "@angular/router": "22.0.2",
    "@ionic/angular": "8.8.11",
    "date-fns": "4.4.0",
    "echarts": "6.1.0",
    "ionicons": "8.0.13",
    "ngx-echarts": "22.0.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular/build": "22.0.3",
    "@angular/cli": "22.0.3",
    "@angular/compiler-cli": "22.0.2",
    "@ionic/angular-toolkit": "12.3.0",
    "@juggle/resize-observer": "3.4.0",
    "bread-compressor-cli": "4.1.0",
    "local-web-server": "5.4.0",
    "prettier": "3.8.4",
    "resize-observer-polyfill": "1.5.1",
    "typescript": "6.0.3"
  }
}
